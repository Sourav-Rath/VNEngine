{
  "nodes": [
    {
      "id": 0,
      "text": "You wake up in a dark room.",
      "next": 1
    },

    {
      "id": 1,
      "text": "There is a key and a locked door.",
      "choices": [
        {
          "text": "Pick up the key",
          "next": 1,
          "setFlags": {
            "hasKey": true
          },
          "events": [
            { "type": "print", "message": "You reach down..." },
            { "type": "delay", "time": 800 },
            { "type": "print", "message": "You picked up the key." }
          ]
        },
        {
          "text": "Gain karma",
          "next": 1,
          "setFlags": {
            "karma": 2
          },
          "events": [
            { "type": "print", "message": "You focus..." },
            { "type": "delay", "time": 800 },
            { "type": "print", "message": "You feel stronger." }
          ]
        },
        {
          "text": "Open the door",
          "next": 2,
          "conditions": {
            "hasKey": true
          },
          "events": [
            { "type": "print", "message": "You insert the key..." },
            { "type": "delay", "time": 1000 },
            { "type": "print", "message": "The lock clicks open." }
          ]
        },
        {
          "text": "Force the door",
          "next": 3,
          "conditions": {
            "karma": 4
          },
          "events": [
            { "type": "print", "message": "You charge at the door..." },
            { "type": "delay", "time": 1000 },
            { "type": "log", "message": "The door breaks open!" }
          ]
        }
      ]
    },

    {
      "id": 2,
      "text": "The door opens. You escaped.",
      "events": [
        { "type": "delay", "time": 500 },
        { "type": "print", "message": "Freedom!" }
      ]
    },

    {
      "id": 3,
      "text": "You failed and got caught.",
      "events": [
        { "type": "delay", "time": 500 },
        { "type": "print", "message": "Game Over." }
      ]
    }
  ]
}