{
  "nodes": [
    {
      "id": 0,
      "text": "You wake up in a dark room.",
      "next": 1
    },

    {
      "id": 1,
      "text": "There is a key and a locked door.",
      "choices": [
        {
          "text": "Pick up the key",
          "next": 1,
          "setFlags": {
            "hasKey": true
          },
          "events": [
            { "type": "print", "message": "You reach down..." },
            { "type": "delay", "time": 800 },
            { "type": "print", "message": "You picked up the key." }
          ]
        },
        {
          "text": "Gain karma",
          "next": 1,
          "setFlags": {
            "karma": 2
          },
          "events": [
            { "type": "print", "message": "You focus..." },
            { "type": "delay", "time": 800 },
            { "type": "print", "message": "You feel stronger." }
          ]
        },


        {
          "text": "Open the door (needs key)",
          "next": 2,
          "conditions": {
            "hasKey": { "eq": true }
          }
        },


        {
          "text": "Force the door (needs karma >= 4)",
          "next": 3,
          "conditions": {
            "karma": { "gte": 4 }
          }
        },


        {
          "text": "Open door (Key OR Strength)",
          "next": 2,
          "conditions": {
            "logic": "OR",
            "rules": [
              { "hasKey": { "eq": true } },
              { "karma": { "gte": 4 } }
            ]
          }
        },


        {
          "text": "Secret Door (Key AND Karma)",
          "next": 2,
          "conditions": {
            "logic": "AND",
            "rules": [
              { "hasKey": { "eq": true } },
              { "karma": { "gte": 4 } }
            ]
          }
        },


        {
          "text": "Chaos Option (Nested Logic)",
          "next": 3,
          "conditions": {
            "logic": "AND",
            "rules": [
              {
                "logic": "OR",
                "rules": [
                  { "karma": { "gte": 4 } },
                  { "karma": { "lt": 0 } }
                ]
              },
              { "hasKey": { "eq": true } }
            ]
          }
        }
      ]
    },

    {
      "id": 2,
      "text": "The door opens. You escaped.",
      "events": [
        { "type": "delay", "time": 500 },
        { "type": "print", "message": "Freedom!" }
      ]
    },

    {
      "id": 3,
      "text": "You failed and got caught.",
      "events": [
        { "type": "delay", "time": 500 },
        { "type": "print", "message": "Game Over." }
      ]
    }
  ]
}