          "next": 2,
          "conditions": {
            "hasKey": { "eq": true }
          },
          "events": [
            { "type": "print", "message": "You unlock the door." }
          ]
        },
        {
          "text": "Force the door",
          "next": 3,
          "conditions": {
            "karma": { "gte": 4 }
